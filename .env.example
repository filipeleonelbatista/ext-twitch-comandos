# App URL (for OAuth redirect – auth callback). Must match the origin used in Twitch Console.
# Add this EXACT URL in Twitch Developer Console → your app → Redirect URIs:
#   https://seu-dominio.vercel.app/api/auth/callback
# (no trailing slash). Ex.:
# NEXT_PUBLIC_APP_URL=https://ext-twitch-comandos.vercel.app

# Extension / Twitch app (from Twitch Developer Console).
# OAuth is used only for broadcaster (sub-check); no viewer login.
# EXTENSION_SECRET=your_extension_secret
# TWITCH_CLIENT_ID=your_twitch_app_client_id
# TWITCH_CLIENT_SECRET=your_twitch_app_client_secret
# Optional: use if the extension has a different Client ID than the OAuth app
# EXTENSION_CLIENT_ID=your_extension_client_id

# Optional: extension version for Send Extension Chat Message (default 0.0.1)
# EXTENSION_VERSION=0.0.3

# Optional: se o panel e o backend estiverem em origens diferentes, defina a URL do backend no frontend
# NEXT_PUBLIC_EBS_URL=https://outro-dominio.com
# NEXT_PUBLIC_EXTENSION_CLIENT_ID=your_extension_client_id

# Optional: em produção, GET /api/test-keys?key=TEST_KEYS_SECRET para testar chaves
# TEST_KEYS_SECRET=uma_senha_secreta

# Firebase (channel settings and history). EBS only.
# Option 1: Put the key file at project root: comandololono-firebase-adminsdk-fbsvc-bf315109fb.json
# Option 2: Set GOOGLE_APPLICATION_CREDENTIALS to the full path of the JSON key file.
# Option 3: FIREBASE_SERVICE_ACCOUNT: JSON string (for serverless, e.g. Vercel).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
